---
import slackUrl    from '../assets/integrations/Slack.svg?url';
import microsoftUrl from '../assets/integrations/Microsoft.svg?url';
import celonisUrl  from '../assets/integrations/Celonis.svg?url';
import googleUrl   from '../assets/integrations/Google.svg?url';
import logoIconRaw from '../assets/logo_icon.svg?raw';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';
---

<section class="hiw" id="how-it-works">
  <div class="container">

    <div class="hiw__header section-fade">
      <p class="hiw__eyebrow">{isDE ? 'Wie es funktioniert' : 'How it works'}</p>
      <h2 class="hiw__heading">
        <span class="hiw__line1">{isDE ? 'Vier Schritte.' : 'Four steps.'}</span>
        <span class="hiw__line2">{isDE ? 'Von der Einrichtung zur Klarheit.' : 'From setup to clarity.'}</span>
      </h2>
    </div>

    <!-- Step 01: Connect knowledge -->
    <div class="hiw__step hiw__step--odd section-fade">
      <div class="hiw__ghost" aria-hidden="true">01</div>
      <div class="hiw__text">
        <p class="hiw__step-eyebrow">{isDE ? 'Schritt 01' : 'Step 01'}</p>
        <h3 class="hiw__step-heading">{isDE ? 'Vorhandenes Wissen verbinden' : 'Connect your existing knowledge'}</h3>
        <p class="hiw__step-body">
          {isDE
            ? 'Verbinden Sie zunächst Ihre expliziten Wissensquellen. Slack, Outlook, Celonis, SAP oder jede andere Quelle. So hat der Interview-Agent den nötigen Kontext, bevor das erste Gespräch beginnt.'
            : 'Start by connecting your explicit knowledge sources. Slack, Outlook, Celonis, SAP or anything else your organisation runs on. This gives the interview agent context before the first conversation begins.'}
        </p>
      </div>
      <div class="hiw__mockup">
        <div class="mock mock--integrations">
          <div class="mock__chrome">
            <div class="mock__dots">
              <span class="mock__dot mock__dot--r"></span>
              <span class="mock__dot mock__dot--y"></span>
              <span class="mock__dot mock__dot--g"></span>
            </div>
            <span class="mock__title">{isDE ? 'Wissensquellen' : 'Knowledge Sources'}</span>
          </div>
          <div class="mock__body">
            <div class="mock__conn-row">
              <div class="mock__conn-logo">
                <img src={slackUrl} width="28" height="28" alt="" aria-hidden="true" />
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">Slack</span>
                <span class="mock__wf-sub">{isDE ? 'Workspace-Nachrichten' : 'Workspace messages'}</span>
              </div>
              <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
            </div>
            <div class="mock__conn-row">
              <div class="mock__conn-logo">
                <img src={microsoftUrl} width="28" height="28" alt="" aria-hidden="true" />
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">Microsoft 365</span>
                <span class="mock__wf-sub">{isDE ? 'Outlook &amp; Teams' : 'Outlook &amp; Teams'}</span>
              </div>
              <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
            </div>
            <div class="mock__conn-row">
              <div class="mock__conn-logo mock__conn-logo--celonis">
                <img src={celonisUrl} width="20" height="20" alt="" aria-hidden="true" />
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">Celonis</span>
                <span class="mock__wf-sub">{isDE ? 'Prozessdaten' : 'Process data'}</span>
              </div>
              <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
            </div>
            <div class="mock__conn-row">
              <div class="mock__conn-logo">
                <img src={googleUrl} width="28" height="28" alt="" aria-hidden="true" />
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">Google Workspace</span>
                <span class="mock__wf-sub">{isDE ? 'Drive &amp; Kalender' : 'Drive &amp; Calendar'}</span>
              </div>
              <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
            </div>
            <div class="mock__conn-agent">
              <div class="mock__conn-agent-icon" set:html={logoIconRaw} />
              <div class="mock__wf-content">
                <span class="mock__wf-title">inplicit Agent</span>
                <span class="mock__wf-sub">{isDE ? '4 Quellen verbunden' : '4 sources connected'}</span>
              </div>
              <span class="mock__status-dot"></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 02: Conversations -->
    <div class="hiw__step hiw__step--even section-fade">
      <div class="hiw__ghost" aria-hidden="true">02</div>
      <div class="hiw__mockup">
        <div class="mock mock--video">
          <div class="mock__video-grid">
            <div class="mock__video-tile">
              <div class="mock__video-avatar">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                </svg>
              </div>
              <span class="mock__video-label">{isDE ? 'Mitarbeitende' : 'Employee'}</span>
            </div>
            <div class="mock__video-tile mock__video-tile--ai">
              <div class="mock__video-logo">
                <span class="mock__agent-icon" set:html={logoIconRaw} />
              </div>
              <span class="mock__video-label">inplicit Agent</span>
            </div>
          </div>
          <div class="mock__video-bar">
            <span class="mock__video-time">5:54</span>
            <div class="mock__video-controls">
              <button class="mock__ctrl" aria-label="mute">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8"/>
                </svg>
              </button>
              <button class="mock__ctrl mock__ctrl--end" aria-label="end call">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.37 2 2 0 0 1 3.61 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.62a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
      <div class="hiw__text">
        <p class="hiw__step-eyebrow">{isDE ? 'Schritt 02' : 'Step 02'}</p>
        <h3 class="hiw__step-heading">{isDE ? 'Gespräche, die wirklich zuhören' : 'Conversations that actually listen'}</h3>
        <p class="hiw__step-body">
          {isDE
            ? 'KI-Agenten sprechen mit jedem in der Organisation, nicht nur mit Führungskräften. Jede Aussage wird kreuzvalidiert, nicht nur protokolliert. So entsteht ein Bild, das ehrlich ist.'
            : 'AI agents talk with everyone in the organisation, not just leadership. Every statement is cross-validated, not just recorded. The result is a picture that is honest.'}
        </p>
        <div class="hiw__stats">
          <div class="hiw__stat">
            <span class="hiw__stat-num">100+</span>
            <span class="hiw__stat-label">{isDE ? 'Gespräche in Stunden' : 'Conversations in hours'}</span>
          </div>
          <div class="hiw__stat">
            <span class="hiw__stat-num">100%</span>
            <span class="hiw__stat-label">{isDE ? 'der Belegschaft erreichbar' : 'Of workforce reached'}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 03: Synthesis -->
    <div class="hiw__step hiw__step--odd section-fade">
      <div class="hiw__ghost" aria-hidden="true">03</div>
      <div class="hiw__text">
        <p class="hiw__step-eyebrow">{isDE ? 'Schritt 03' : 'Step 03'}</p>
        <h3 class="hiw__step-heading">{isDE ? 'Ergebnisse verdichten sich' : 'Results come together'}</h3>
        <p class="hiw__step-body">
          {isDE
            ? 'Hunderte Gespräche laufen gleichzeitig. Die KI erkennt Muster, bildet Cluster und trennt Signal von Rauschen. Ohne manuelle Auswertung, ohne Tage des Wartens.'
            : 'Hundreds of conversations happen at once. The AI spots patterns, forms clusters, and separates signal from noise. No manual analysis, no days of waiting.'}
        </p>
        <div class="hiw__stats">
          <div class="hiw__stat">
            <span class="hiw__stat-num">3-4</span>
            <span class="hiw__stat-label">{isDE ? 'Tage bis zu ersten Erkenntnissen' : 'Days to first insights'}</span>
          </div>
          <div class="hiw__stat">
            <span class="hiw__stat-num">0</span>
            <span class="hiw__stat-label">{isDE ? 'Manuelle Analyse nötig' : 'Manual analysis needed'}</span>
          </div>
        </div>
      </div>
      <div class="hiw__mockup">
        <div class="mock mock--workflow">
          <div class="mock__chrome">
            <div class="mock__dots">
              <span class="mock__dot mock__dot--r"></span>
              <span class="mock__dot mock__dot--y"></span>
              <span class="mock__dot mock__dot--g"></span>
            </div>
            <span class="mock__title">{isDE ? 'Synthese läuft' : 'Synthesis running'}</span>
          </div>
          <div class="mock__body">
            <div class="mock__wf-item mock__wf-item--done">
              <div class="mock__wf-icon">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Gespräche geführt' : 'Conversations completed'}</span>
                <span class="mock__wf-sub">{isDE ? '1.247 Stimmen erfasst' : '1,247 voices recorded'}</span>
              </div>
              <span class="mock__wf-status mock__wf-status--done">{isDE ? 'Fertig' : 'Done'}</span>
            </div>
            <div class="mock__wf-item mock__wf-item--active">
              <div class="mock__wf-icon mock__wf-icon--spin">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Cluster werden gebildet' : 'Clusters forming'}</span>
                <span class="mock__wf-sub">{isDE ? 'Signalquellen werden verbunden' : 'Connecting signal sources'}</span>
              </div>
              <span class="mock__wf-status mock__wf-status--active">{isDE ? 'Aktiv' : 'Active'}</span>
            </div>
            <div class="mock__wf-item mock__wf-item--pending">
              <div class="mock__wf-icon mock__wf-icon--pending">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Erkenntnisse generieren' : 'Generating insights'}</span>
                <span class="mock__wf-sub">{isDE ? 'Bereitet Ergebnisse vor' : 'Preparing your output'}</span>
              </div>
              <span class="mock__wf-status">{isDE ? 'Ausstehend' : 'Pending'}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 04: Output picture -->
    <div class="hiw__step hiw__step--even section-fade">
      <div class="hiw__ghost" aria-hidden="true">04</div>
      <div class="hiw__mockup">
        <div class="mock mock--output">
          <div class="mock__chrome">
            <div class="mock__dots">
              <span class="mock__dot mock__dot--r"></span>
              <span class="mock__dot mock__dot--y"></span>
              <span class="mock__dot mock__dot--g"></span>
            </div>
            <span class="mock__title">{isDE ? 'Ergebnisübersicht' : 'Results overview'}</span>
          </div>
          <div class="mock__body">
            <div class="mock__wf-item mock__wf-item--done">
              <div class="mock__wf-icon">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Schmerzpunkte' : 'Pain Points'}</span>
                <span class="mock__wf-sub">{isDE ? 'In 5 Teams identifiziert' : 'Identified across 5 teams'}</span>
              </div>
              <span class="mock__out-count">14</span>
            </div>
            <div class="mock__wf-item mock__wf-item--done mock__wf-item--accent">
              <div class="mock__wf-icon mock__wf-icon--accent">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Chancen' : 'Opportunities'}</span>
                <span class="mock__wf-sub">{isDE ? 'Handlungsfelder bereit' : 'Action areas ready'}</span>
              </div>
              <span class="mock__out-count mock__out-count--accent">8</span>
            </div>
            <div class="mock__wf-item mock__wf-item--done">
              <div class="mock__wf-icon">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Prozesslücken' : 'Process Gaps'}</span>
                <span class="mock__wf-sub">{isDE ? 'Priorisiert nach Impact' : 'Prioritised by impact'}</span>
              </div>
              <span class="mock__out-count">11</span>
            </div>
            <div class="mock__wf-item mock__wf-item--done">
              <div class="mock__wf-icon">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Wissenskarte' : 'Knowledge Map'}</span>
                <span class="mock__wf-sub">{isDE ? 'Cluster visualisiert' : 'Clusters visualised'}</span>
              </div>
              <span class="mock__out-count">3</span>
            </div>
          </div>
        </div>
      </div>
      <div class="hiw__text">
        <p class="hiw__step-eyebrow">{isDE ? 'Schritt 04' : 'Step 04'}</p>
        <h3 class="hiw__step-heading">{isDE ? 'Sie sehen das vollständige Bild' : 'You see the full picture'}</h3>
        <p class="hiw__step-body">
          {isDE
            ? 'Schmerzpunkte, Chancen, Prozesslücken und eine Wissenskarte. Geordnet, priorisiert und bereit für Entscheidungen. Kein 60-seitiger Bericht, den niemand liest.'
            : 'Pain points, opportunities, process gaps, and a knowledge map. Organised, prioritised, and ready for decisions. No 60-page report that nobody reads.'}
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  .hiw {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .hiw { padding: var(--space-24) 0 var(--space-32); }
  }

  .hiw__header {
    margin-bottom: var(--space-24);
  }

  @media (max-width: 767px) {
    .hiw__header { margin-bottom: var(--space-16); }
  }

  .hiw__eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .hiw__heading {
    font-size: clamp(var(--text-xl), 5vw, var(--text-3xl));
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.0;
    display: flex;
    flex-direction: column;
  }

  .hiw__line1 { color: var(--color-text-primary); }
  .hiw__line2 { color: var(--color-text-primary); opacity: 0.3; }

  /* Step blocks */
  .hiw__step {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    padding: var(--space-16) 0 var(--space-24);
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .hiw__step {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
      align-items: center;
      padding: var(--space-24) 0;
    }

    .hiw__step--even .hiw__text  { order: 2; }
    .hiw__step--even .hiw__mockup { order: 1; }
  }

  /* Ghost number */
  .hiw__ghost {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    font-size: clamp(72px, 18vw, 100px);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 1;
    color: var(--color-border);
    z-index: 0;
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
    filter: blur(2px);
    opacity: 0.8;
  }

  @media (min-width: 768px) {
    .hiw__ghost {
      top: 50%;
      right: auto;
      left: 50%;
      font-size: clamp(160px, 22vw, 320px);
      filter: blur(3px);
    }
    .hiw__step--odd .hiw__ghost  { transform: translate(-150%, -50%); }
    .hiw__step--even .hiw__ghost { transform: translate(20%, -50%); }
  }

  .hiw__text {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hiw__step-eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .hiw__step-heading {
    font-size: clamp(var(--text-xl), 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }

  .hiw__step-body {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.8;
    max-width: 420px;
  }

  /* Stats */
  .hiw__stats {
    display: flex;
    gap: var(--space-8);
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .hiw__stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .hiw__stat-num {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    line-height: 1;
  }

  .hiw__stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .hiw__mockup {
    position: relative;
    z-index: 1;
  }

  /* ---- Shared mock chrome ---- */
  .mock {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    font-family: var(--font-family);
  }

  .mock__chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-surface-elevated);
  }

  .mock__dots { display: flex; gap: 5px; flex-shrink: 0; }
  .mock__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }
  .mock__dot--r { background: #ef4444; }
  .mock__dot--y { background: #f59e0b; }
  .mock__dot--g { background: #22c55e; }

  .mock__title {
    font-size: 11px;
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .mock__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* ---- Connection list (Step 01) ---- */
  .mock--integrations .mock__body {
    padding: 0;
    gap: 0;
  }

  .mock__conn-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .mock__conn-logo {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mock__conn-logo img {
    display: block;
    width: 28px;
    height: 28px;
  }

  /* Celonis has no background rect — wrap in a light tile so the dark path is visible */
  .mock__conn-logo--celonis {
    background: #eaeaea;
    border-radius: var(--radius-card);
    padding: 4px;
    box-sizing: border-box;
  }

  .mock__conn-logo--celonis img {
    width: 100%;
    height: 100%;
  }

  .mock__conn-pill {
    font-size: 10px;
    font-weight: 600;
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.2);
    padding: 2px 7px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* Agent footer row */
  .mock__conn-agent {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-accent-light);
    border-top: 1px solid var(--color-accent-muted);
  }

  .mock__conn-agent-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mock__conn-agent-icon :global(svg) {
    display: block;
    width: 28px;
    height: 28px;
  }

  .mock__conn-agent-icon :global(path) { fill: #000000; }
  .mock__conn-agent-icon :global(rect)  { fill: var(--color-accent); }

  /* ---- Video call (Step 02) ---- */
  .mock--video { background-color: var(--color-surface-elevated); }

  .mock__video-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
    padding: var(--space-3);
