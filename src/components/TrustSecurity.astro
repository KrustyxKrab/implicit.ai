---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

interface TrustItem {
  icon: string;
  title: string;
  body: string;
}

const items: TrustItem[] = isDE ? [
  {
    icon: 'shield',
    title: 'DSGVO & EU AI Act konform',
    body: 'Auftragsverarbeitungsvertrag, Betriebsrat-ready, klare Rechtsgrundlagen — alles, was Ihr Unternehmen für einen rechtssicheren Einsatz braucht.',
  },
  {
    icon: 'server',
    title: 'Daten in der EU',
    body: 'Rechenzentrum in Frankfurt am Main. Gesprächsdaten verlassen die EU nicht — nach dem EU-Data-Boundary-Prinzip.',
  },
  {
    icon: 'lock',
    title: 'Kein Training auf Interviews',
    body: 'Gespräche und Antworten Ihrer Mitarbeitenden fließen nicht in Modelltraining. Null. Vertraglich zugesichert.',
  },
  {
    icon: 'user',
    title: 'Freiwillig & anonym',
    body: 'Mitarbeitende entscheiden selbst, was sie teilen. inplicit wertet nur aus, was freiwillig gegeben und vollständig anonymisiert wurde.',
  },
] : [
  {
    icon: 'shield',
    title: 'GDPR & EU AI Act compliant',
    body: 'Data processing agreement, works-council ready, clear legal framework — everything your organisation needs for compliant deployment.',
  },
  {
    icon: 'server',
    title: 'Data stays in the EU',
    body: 'Data centre in Frankfurt am Main. Interview data never leaves the EU — following the EU Data Boundary principle.',
  },
  {
    icon: 'lock',
    title: 'No training on interviews',
    body: 'Conversations and employee responses do not flow into model training. Zero. Contractually guaranteed.',
  },
  {
    icon: 'user',
    title: 'Voluntary & anonymous',
    body: 'Employees decide what they share. inplicit only analyses what is given voluntarily and fully anonymised.',
  },
];
---

<section class="trust" id="trust-security">
  <div class="container">

    <div class="trust__header section-fade">
      <span class="trust__badge">
        {isDE ? 'Vertrauen & Sicherheit' : 'Trust & Security'}
      </span>
      <h2 class="trust__heading">
        <span class="trust__line1">
          {isDE ? 'Sicherheit ist' : 'Security is'}
        </span>
        <span class="trust__line2">
          {isDE ? 'keine Option.' : 'not optional.'}
        </span>
      </h2>
      <p class="trust__sub">
        {isDE
          ? 'Organisationen arbeiten mit sensiblen Daten. Deshalb ist Vertrauen für uns kein Feature, sondern das Fundament.'
          : 'Organisations work with sensitive data. That is why trust is not a feature for us — it is the foundation.'}
      </p>
    </div>

    <div class="trust__grid">
      {items.map((item, i) => (
        <div class="trust__item section-fade" style={`--delay: ${i * 60}ms`}>
          <div class="trust__item-icon" aria-hidden="true">
            {item.icon === 'shield' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            )}
            {item.icon === 'server' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/>
                <line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
              </svg>
            )}
            {item.icon === 'lock' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            )}
            {item.icon === 'user' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            )}
          </div>
          <div class="trust__item-body">
            <h3 class="trust__item-title">{item.title}</h3>
            <p class="trust__item-text">{item.body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .trust {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .trust { padding: var(--space-24) 0; }
  }

  .trust__header {
    margin-bottom: var(--space-12);
    max-width: 620px;
  }

  .trust__badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
    opacity: 0.85;
  }

  .trust__heading {
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    display: flex;
    flex-direction: column;
    gap: 0.06em;
    margin-bottom: var(--space-4);
  }

  .trust__line1 { color: var(--color-text-primary); }
  .trust__line2 { color: var(--color-text-primary); opacity: 0.3; }

  .trust__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .trust__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }

  @media (min-width: 640px) {
    .trust__grid { grid-template-columns: repeat(2, 1fr); }
  }

  .trust__item {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background-color: var(--color-surface);
    transition: border-color 0.2s var(--ease-smooth);
  }

  .trust__item:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
  }

  .trust__item-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-ui);
    background-color: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .trust__item-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .trust__item-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
  }

  .trust__item-text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
</style>
