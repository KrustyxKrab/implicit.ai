---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

interface TrustItem {
  title: string;
  body: string;
}

const items: TrustItem[] = isDE ? [
  {
    title: 'DSGVO & EU AI Act konform',
    body: 'Auftragsverarbeitungsvertrag, Betriebsrat-ready, klare Rechtsgrundlagen — alles, was Ihr Unternehmen für einen rechtssicheren Einsatz braucht.',
  },
  {
    title: 'Daten in der EU',
    body: 'Rechenzentrum in Frankfurt am Main. Gesprächsdaten verlassen die EU nicht — nach dem EU-Data-Boundary-Prinzip.',
  },
  {
    title: 'Kein Training auf Interviews',
    body: 'Gespräche und Antworten Ihrer Mitarbeitenden fließen nicht in Modelltraining. Null. Vertraglich zugesichert.',
  },
  {
    title: 'Freiwillig & anonym',
    body: 'Mitarbeitende entscheiden selbst, was sie teilen. inplicit wertet nur aus, was freiwillig gegeben und vollständig anonymisiert wurde.',
  },
] : [
  {
    title: 'GDPR & EU AI Act compliant',
    body: 'Data processing agreement, works-council ready, clear legal framework — everything your organisation needs for compliant deployment.',
  },
  {
    title: 'Data stays in the EU',
    body: 'Data centre in Frankfurt am Main. Interview data never leaves the EU — following the EU Data Boundary principle.',
  },
  {
    title: 'No training on interviews',
    body: 'Conversations and employee responses do not flow into model training. Zero. Contractually guaranteed.',
  },
  {
    title: 'Voluntary & anonymous',
    body: 'Employees decide what they share. inplicit only analyses what is given voluntarily and fully anonymised.',
  },
];
---

<section class="trust" id="trust-security">
  <div class="container">

    <div class="trust__header section-fade">
      <p class="trust__eyebrow">
        {isDE ? 'Vertrauen & Sicherheit' : 'Trust & Security'}
      </p>
      <h2 class="trust__heading">
        <span class="trust__line1">{isDE ? 'Sicherheit ist' : 'Security is'}</span>
        <span class="trust__line2">{isDE ? 'keine Option.' : 'not optional.'}</span>
      </h2>
      <p class="trust__sub">
        {isDE
          ? 'Organisationen arbeiten mit sensiblen Daten. Deshalb ist Vertrauen für uns kein Feature, sondern das Fundament.'
          : 'Organisations work with sensitive data. That is why trust is not a feature for us — it is the foundation.'}
      </p>
    </div>

    <div class="trust__grid">
      {items.map((item, i) => (
        <div class="trust__col section-fade" style={`--delay: ${i * 80}ms`}>
          <div class="trust__icon" aria-hidden="true">
            {i === 0 && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            )}
            {i === 1 && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="5" rx="1"/>
                <rect x="2" y="10" width="20" height="5" rx="1"/>
                <rect x="2" y="17" width="20" height="4" rx="1"/>
                <circle cx="18.5" cy="5.5" r="0.5" fill="currentColor"/>
                <circle cx="18.5" cy="12.5" r="0.5" fill="currentColor"/>
              </svg>
            )}
            {i === 2 && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                <line x1="8" y1="3" x2="16" y2="21"/>
              </svg>
            )}
            {i === 3 && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                <path d="M18 3l2 2-5 5"/>
              </svg>
            )}
          </div>
          <h3 class="trust__col-title">{item.title}</h3>
          <p class="trust__col-body">{item.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .trust {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .trust { padding: var(--space-24) 0; }
  }

  .trust__header {
    margin-bottom: var(--space-16);
    max-width: 560px;
  }

  @media (max-width: 767px) {
    .trust__header { margin-bottom: var(--space-10); }
  }

  .trust__eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .trust__heading {
    font-size: clamp(var(--text-xl), 5vw, var(--text-2xl));
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.0;
    display: flex;
    flex-direction: column;
    gap: 0.05em;
    margin-bottom: var(--space-6);
  }

  .trust__line1 { color: var(--color-text-primary); }
  .trust__line2 { color: var(--color-text-primary); opacity: 0.3; }

  .trust__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  .trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .trust__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .trust__grid { grid-template-columns: 1fr; }
  }

  .trust__col {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    border-right: 1px solid var(--color-border);
  }

  .trust__col:last-child {
    border-right: none;
  }

  @media (max-width: 900px) {
    .trust__col:nth-child(2) { border-right: none; }
    .trust__col:nth-child(3) { border-right: 1px solid var(--color-border); }
    .trust__col:nth-child(1),
    .trust__col:nth-child(2) { border-bottom: 1px solid var(--color-border); }
  }

  @media (max-width: 540px) {
    .trust__col { border-right: none; border-bottom: 1px solid var(--color-border); }
    .trust__col:last-child { border-bottom: none; }
  }

  .trust__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-ui);
    color: var(--color-accent);
    flex-shrink: 0;
    margin-bottom: var(--space-2);
  }

  .trust__col-title {
    font-size: var(--text-base);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--color-text-primary);
  }

  .trust__col-body {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  @media (max-width: 767px) {
    .trust__col { padding: var(--space-6); }
  }
</style>
