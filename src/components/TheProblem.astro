---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
---

<section class="problem" id="the-problem">
  <div class="container">
    <p class="problem__eyebrow section-fade">
      {lang === 'de' ? 'Das Problem' : 'The Problem'}
    </p>

    <h2 class="problem__heading section-fade">
      <span class="problem__heading-line1">{lang === 'de' ? 'Was in Ihrer Organisation' : 'What goes unheard'}</span>
      <span class="problem__heading-line2">{lang === 'de' ? 'ungehört bleibt.' : 'costs organisations everything.'}</span>
    </h2>

    <div class="problem__cols">
      <div class="problem__col section-fade" style="--delay: 0ms">
        <div class="problem__col-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 4v4m0 4h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="problem__col-title">
          {lang === 'de' ? 'Signalunterdrückung' : 'Signal suppression'}
        </h3>
        <p class="problem__col-body">
          {lang === 'de'
            ? 'Ihre wertvollsten Erkenntnisse entstehen an der Front — bei den Menschen, die täglich mit Kunden, Prozessen und Reibungspunkten arbeiten. Diese Signale verschwinden leise in der Hierarchie, lange bevor sie die Entscheidungsebene erreichen.'
            : 'Your most valuable insights originate at the front line — with the people who work daily with customers, processes, and friction points. These signals quietly disappear up the hierarchy long before they reach decision level.'}
        </p>
        <p class="problem__col-body problem__col-body--callout">
          {lang === 'de'
            ? 'Das ist kein Kommunikationsproblem. Es ist ein strukturelles.'
            : "This isn't a communication problem. It's a structural one."}
        </p>
      </div>

      <div class="problem__col section-fade" style="--delay: 100ms">
        <div class="problem__col-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 10h14M3 5h14M3 15h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="problem__col-title">
          {lang === 'de' ? 'Aggregationsversagen' : 'Aggregation failure'}
        </h3>
        <p class="problem__col-body">
          {lang === 'de'
            ? 'Bestehende Tools aggregieren, was leicht zu messen ist — nicht, was wichtig ist. Umfragen erfassen Meinungen, nicht Erkenntnisse. Meetings verdichten Erkenntnisse zu Konsens. Berichte filtern das Unbequeme heraus.'
            : 'Existing tools aggregate what is easy to measure — not what matters. Surveys capture opinions, not insights. Meetings compress insights into consensus. Reports filter out the uncomfortable.'}
        </p>
        <p class="problem__col-body problem__col-body--callout">
          {lang === 'de'
            ? 'Kodak wusste, dass die Digitalkamera kommen würde. Das Wissen war vorhanden. Die Aggregation versagte.'
            : 'Kodak knew the digital camera was coming. The knowledge existed. The aggregation failed.'}
        </p>
      </div>
    </div>

    <div class="problem__cta-wrap section-fade">
      <a href="#request-pilot" class="problem__cta">
        {lang === 'de' ? 'Pilot anfragen' : 'Request Pilot'}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .problem {
    padding: var(--space-24) 0;
    border-top: 1px solid var(--color-border);
    background-color: var(--color-surface);
  }

  @media (max-width: 767px) {
    .problem {
      padding: var(--space-12) 0;
    }
  }

  .problem__eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .problem__heading {
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
    margin-bottom: var(--space-12);
  }

  @media (max-width: 767px) {
    .problem__heading {
      margin-bottom: var(--space-8);
    }
  }

  .problem__heading-line1 {
    color: var(--color-text-primary);
  }

  .problem__heading-line2 {
    color: var(--color-text-tertiary);
  }

  .problem__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .problem__cols {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }
  }

  .problem__col {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    box-shadow: var(--shadow-xs);
    transition: box-shadow 0.25s ease;
  }

  @media (max-width: 767px) {
    .problem__col {
      padding: var(--space-6);
    }
    .problem__cols {
      margin-bottom: var(--space-8);
    }
  }

  .problem__col:hover {
    box-shadow: var(--shadow-md);
  }

  .problem__col-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-accent-light);
    border-radius: var(--radius-ui);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .problem__col-title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text-primary);
  }

  .problem__col-body {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .problem__col-body--callout {
    font-weight: 500;
    color: var(--color-text-primary);
    font-style: italic;
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-4);
  }

  .problem__cta-wrap {
    margin-top: var(--space-4);
  }

  .problem__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
    font-size: var(--text-base);
    font-weight: 600;
    border-radius: var(--radius-ui);
    transition: background-color 0.2s ease, color 0.2s ease, gap 0.2s ease;
  }

  .problem__cta:hover {
    background-color: var(--color-accent);
    color: #ffffff;
    gap: var(--space-3);
  }
</style>
