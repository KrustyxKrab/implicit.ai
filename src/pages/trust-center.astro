---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Trust Center — inplicit.ai"
  description="Transparenz über Datenschutz, Infrastruktur und KI-Einsatz bei inplicit. DSGVO-konform, EU-gehostet, Betriebsrat-ready."
  lang="de"
>
  <Nav lang="de" />

  <main class="tc">

    <!-- ─── HERO ─── -->
    <section class="tc__hero">
      <div class="container">
        <p class="tc__eyebrow">Trust Center</p>
        <h1 class="tc__hero-heading">
          <span class="tc__hero-line1">Vertrauen</span>
          <span class="tc__hero-line2">ist die Grundlage.</span>
        </h1>
        <p class="tc__hero-sub">
          Wo Mitarbeiterdaten und implizites Organisationswissen verarbeitet werden, muss alles nachvollziehbar sein. Hier steht, wo inplicit läuft, wer beteiligt ist und wie wir DSGVO, EU AI Act und Betriebsratsanforderungen erfüllen.
        </p>

        <div class="tc__badges">
          <div class="tc__badge">
            <span class="tc__badge-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </span>
            <div>
              <strong>DSGVO &amp; AV-Vertrag</strong>
              <span>Art. 28 DSGVO, unterzeichnet pro Unternehmen</span>
            </div>
          </div>
          <div class="tc__badge">
            <span class="tc__badge-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </span>
            <div>
              <strong>EU-Server</strong>
              <span>Frankfurt · europe-west · ISO 27001</span>
            </div>
          </div>
          <div class="tc__badge">
            <span class="tc__badge-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </span>
            <div>
              <strong>Betriebsrat-ready</strong>
              <span>Transparenzanforderungen vollständig erfüllt</span>
            </div>
          </div>
          <div class="tc__badge">
            <span class="tc__badge-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M4.93 4.93l14.14 14.14"/></svg>
            </span>
            <div>
              <strong>Zero Data Retention</strong>
              <span>Keine Mitarbeiterdaten im KI-Training</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── DOKUMENTE ─── -->
    <section class="tc__section section-fade" id="tc-dokumente">
      <div class="container">
        <div class="tc__section-inner">
          <div class="tc__section-label">
            <span class="tc__section-num">01</span>
            <span>Dokumente</span>
          </div>
          <div class="tc__section-body">
            <h2 class="tc__section-heading">Der AV-Vertrag im Original</h2>
            <p class="tc__section-text">
              Der vollständige Auftragsverarbeitungsvertrag nach Art. 28 DSGVO inklusive technisch-organisatorischer Maßnahmen (TOMs) und Subprozessoren-Liste. Wird pro Unternehmen beim Onboarding unterzeichnet — vor dem ersten Interview.
            </p>
            <a href="mailto:hello@inplicit.ai?subject=AV-Vertrag%20Anfrage" class="tc__doc-btn">
              AV-Vertrag anfordern
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>

            <div class="tc__contact-box">
              <p class="tc__contact-heading">Fragen zu Datenschutz oder Compliance?</p>
              <p class="tc__contact-text">Wir antworten persönlich. Für formale Anfragen, Audit-Wünsche oder Fragen zu Subprozessoren:</p>
              <a href="mailto:hello@inplicit.ai" class="tc__contact-link">hello@inplicit.ai</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── DATENSCHUTZ ─── -->
    <section class="tc__section section-fade" id="tc-datenschutz">
      <div class="container">
        <div class="tc__section-inner">
          <div class="tc__section-label">
            <span class="tc__section-num">02</span>
            <span>Datenschutz</span>
          </div>
          <div class="tc__section-body">
            <h2 class="tc__section-heading">DSGVO, Betriebsrat und Betroffenenrechte</h2>
            <p class="tc__section-text">
              Die Verarbeitung erfolgt ausschließlich im Auftrag und nach Weisung des jeweiligen Unternehmens — auf Grundlage eines AV-Vertrags nach Art. 28 DSGVO. Betriebsräte erhalten auf Anfrage vollständige Transparenz über Datenflüsse, Verarbeitungszwecke und eingesetzte Subprozessoren. Betroffenenrechte werden über das Unternehmen als Verantwortlichen bearbeitet.
            </p>
            <ul class="tc__list">
              <li>Art. 28 DSGVO Auftragsverarbeitung</li>
              <li>Pseudonymisierung von Interview-Inhalten auf Wunsch</li>
              <li>48-Stunden-Meldefrist bei Datenschutzverletzungen</li>
              <li>Löschung oder Rückgabe aller Daten nach Vertragsende</li>
              <li>EU AI Act — Transparenz- und Kontrollpflichten erfüllt</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── INFRASTRUKTUR ─── -->
    <section class="tc__section section-fade" id="tc-infrastruktur">
      <div class="container">
        <div class="tc__section-inner">
          <div class="tc__section-label">
            <span class="tc__section-num">03</span>
            <span>Infrastruktur</span>
          </div>
          <div class="tc__section-body">
            <h2 class="tc__section-heading">EU-Hosting mit zertifizierten Providern</h2>
            <p class="tc__section-text">
              inplicit läuft auf AWS in der Region eu-central-1 (Frankfurt) — kein eigenes Rechenzentrum. Alle Infrastruktur-Provider sind ISO-27001- und SOC-2-zertifiziert. Logische Mandantentrennung per Organisations-ID, Endgeräte sind festplattenverschlüsselt.
            </p>
            <ul class="tc__list">
              <li>Verschlüsselung: AES-256 at rest, TLS 1.2+ in transit</li>
              <li>Redundante Availability Zones + automatische Point-in-Time-Backups</li>
              <li>DDoS-Schutz und Web Application Firewall</li>
              <li>2FA-Pflicht für alle Admin-Zugänge</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── DATENVERARBEITUNG ─── -->
    <section class="tc__section section-fade" id="tc-daten">
      <div class="container">
        <div class="tc__section-inner">
          <div class="tc__section-label">
            <span class="tc__section-num">04</span>
            <span>Datenverarbeitung</span>
          </div>
          <div class="tc__section-body">
            <h2 class="tc__section-heading">Was rein- und was rausgeht</h2>
            <p class="tc__section-text">
              inplicit verarbeitet nur, was zur Erfüllung der beauftragten Leistung erforderlich ist. Nichts fließt ins Modelltraining, nichts verlässt die EU-Infrastruktur für Kernprozesse.
            </p>
            <div class="tc__data-cols">
              <div class="tc__data-col">
                <p class="tc__data-col-label">Input</p>
                <p class="tc__data-col-text">Interview-Transkripte (Audio/Text), angebundene Wissensquellen (Slack, Outlook, Celonis, SAP) und optionale Struktur- und Rollendaten</p>
              </div>
              <div class="tc__data-col">
                <p class="tc__data-col-label">Output</p>
                <p class="tc__data-col-text">Erkenntnisberichte, Signalcluster, Handlungsempfehlungen — ausschließlich an autorisierte Empfänger im Unternehmen</p>
              </div>
              <div class="tc__data-col">
                <p class="tc__data-col-label">Stammdaten</p>
                <p class="tc__data-col-text">Namen, E-Mail-Adressen, Abteilungszugehörigkeit, technische Log-Dateien</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── KI-TRANSPARENZ ─── -->
    <section class="tc__section section-fade" id="tc-ki">
      <div class="container">
        <div class="tc__section-inner">
          <div class="tc__section-label">
            <span class="tc__section-num">05</span>
            <span>KI-Transparenz</span>
          </div>
          <div class="tc__section-body">
            <h2 class="tc__section-heading">Welche Modelle, welche Zusagen</h2>
            <p class="tc__section-text">
              inplicit nutzt spezialisierte Large Language Models — alle EU-gehostet, alle mit vertraglich zugesichertem Zero Data Retention. Kein vollautomatischer Versand von Ergebnissen: inplicit erstellt, die verantwortliche Person im Unternehmen entscheidet.
            </p>
            <ul class="tc__list">
              <li>Anthropic Claude (via AWS Bedrock · eu-central-1, Frankfurt)</li>
              <li>Zero Data Retention vertraglich für alle Modelle zugesichert</li>
              <li>Human-in-the-Loop: kein automatisierter Versand von Erkenntnissen</li>
              <li>EU AI Act — Hochrisiko-Klassifizierung geprüft, Transparenzpflichten erfüllt</li>
            </ul>
            <a href="#tc-subprozessoren" class="tc__link">
              Vollständige Liste der Subprozessoren ↓
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SUBPROZESSOREN ─── -->
    <section class="tc__section section-fade" id="tc-subprozessoren">
      <div class="container">
        <div class="tc__section-inner">
          <div class="tc__section-label">
            <span class="tc__section-num">06</span>
            <span>Subprozessoren</span>
          </div>
          <div class="tc__section-body">
            <h2 class="tc__section-heading">Wer auf welche Daten Zugriff hat</h2>
            <p class="tc__section-text">
              Alle Unterauftragsverarbeiter, nach Funktion gruppiert. Jede Integration mit klarem Zweck, Standort und — wo relevant — der Rechtsgrundlage für eventuelle Drittstaaten-Transfers.
            </p>

            <div class="tc__sp-group">
              <p class="tc__sp-group-label">LLM / KI</p>
              <div class="tc__sp-table">
                <div class="tc__sp-row tc__sp-row--head">
                  <span>Anbieter</span>
                  <span>Funktion</span>
                  <span>Standort</span>
                </div>
                <div class="tc__sp-row">
                  <span><strong>Anthropic</strong><br/><small>Claude (via AWS Bedrock)</small></span>
                  <span>Interview-Agent, Synthese, Erkenntnisgenerie&shy;rung</span>
                  <span>EU · Frankfurt</span>
                </div>
              </div>
            </div>

            <div class="tc__sp-group">
              <p class="tc__sp-group-label">Infrastruktur / Hosting</p>
              <div class="tc__sp-table">
                <div class="tc__sp-row tc__sp-row--head">
                  <span>Anbieter</span>
                  <span>Funktion</span>
                  <span>Standort</span>
                </div>
                <div class="tc__sp-row">
                  <span><strong>Amazon Web Services</strong><br/><small>EC2, RDS, S3, CloudFront</small></span>
                  <span>Application-Hosting, Datenbank, Datei&shy;speicher</span>
                  <span>EU · eu-central-1 (Frankfurt)</span>
                </div>
                <div class="tc__sp-row">
                  <span><strong>Amazon Web Services</strong><br/><small>CloudWatch</small></span>
                  <span>Logs, Metriken, Health-Checks</span>
                  <span>EU · eu-central-1 (Frankfurt)</span>
                </div>
              </div>
            </div>

            <div class="tc__sp-group">
              <p class="tc__sp-group-label">Analytics &amp; Observability</p>
              <div class="tc__sp-table">
                <div class="tc__sp-row tc__sp-row--head">
                  <span>Anbieter</span>
                  <span>Funktion</span>
                  <span>Standort</span>
                </div>
                <div class="tc__sp-row">
                  <span><strong>PostHog Inc.</strong><br/><small>PostHog Cloud EU</small></span>
                  <span>Produkt-Analytics, Nutzungsmetriken</span>
                  <span>EU · Frankfurt</span>
                </div>
              </div>
            </div>

            <div class="tc__sp-group">
              <p class="tc__sp-group-label">Transaktionale E-Mail</p>
              <div class="tc__sp-table">
                <div class="tc__sp-row tc__sp-row--head">
                  <span>Anbieter</span>
                  <span>Funktion</span>
                  <span>Standort</span>
                </div>
                <div class="tc__sp-row">
                  <span><strong>Amazon Web Services EMEA</strong><br/><small>Amazon SES</small></span>
                  <span>Verifikations- und Systemmails</span>
                  <span>EU · Frankfurt (eu-central-1)</span>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ─── FAQ ─── -->
    <section class="tc__section section-fade" id="tc-faq">
      <div class="container">
        <div class="tc__section-inner">
          <div class="tc__section-label">
            <span class="tc__section-num">07</span>
            <span>FAQ</span>
          </div>
          <div class="tc__section-body">
            <h2 class="tc__section-heading">Noch Fragen zur Compliance?</h2>

            <div class="tc__faq">

              <details class="tc__faq-item">
                <summary class="tc__faq-q">
                  Werden Mitarbeiterdaten zum KI-Training verwendet?
                  <span class="tc__faq-icon" aria-hidden="true"></span>
                </summary>
                <p class="tc__faq-a">Nein. inplicit nutzt ausschließlich Large Language Models mit vertraglich zugesichertem Zero Data Retention. Interview-Inhalte und Organisationsdaten werden nicht für das Training der Modelle verwendet und nach der Verarbeitung nicht dauerhaft beim Modell-Anbieter gespeichert.</p>
              </details>

              <details class="tc__faq-item">
                <summary class="tc__faq-q">
                  Wer hat Zugriff auf Interview-Inhalte?
                  <span class="tc__faq-icon" aria-hidden="true"></span>
                </summary>
                <p class="tc__faq-a">Ausschließlich autorisierte Personen im Unternehmen. Inhalte werden nicht an Dritte weitergegeben. Der Zugriff für inplicit-Mitarbeitende beschränkt sich auf technisch notwendige Wartungs- und Support-Tätigkeiten und ist vertraglich geregelt.</p>
              </details>

              <details class="tc__faq-item">
                <summary class="tc__faq-q">
                  Wie ist die Anonymisierung von Interview-Inhalten geregelt?
                  <span class="tc__faq-icon" aria-hidden="true"></span>
                </summary>
                <p class="tc__faq-a">Auf Wunsch erfolgt eine Pseudonymisierung der Transkripte, bevor Erkenntnisse an Führungskräfte übergeben werden. Das Unternehmen definiert dabei den gewünschten Grad der Anonymisierung. Technisch werden Name und Rollendaten getrennt von Gesprächsinhalten gespeichert.</p>
              </details>

              <details class="tc__faq-item">
                <summary class="tc__faq-q">
                  Wo werden die Daten gespeichert?
                  <span class="tc__faq-icon" aria-hidden="true"></span>
                </summary>
                <p class="tc__faq-a">Primär in der EU. Application-Hosting und Datenbank laufen auf AWS in der Region eu-central-1 (Frankfurt). KI-Inferenz erfolgt über AWS Bedrock ebenfalls in der EU. Kein Datentransfer in Drittstaaten für Kernprozesse.</p>
              </details>

              <details class="tc__faq-item">
                <summary class="tc__faq-q">
                  Wie schnell werden Sicherheitsvorfälle gemeldet?
                  <span class="tc__faq-icon" aria-hidden="true"></span>
                </summary>
                <p class="tc__faq-a">Innerhalb von 48 Stunden nach erster Kenntnis. Die Meldung enthält Art und Umfang der Verletzung, betroffene Datenkategorien, Kontaktdaten der zuständigen Personen, wahrscheinliche Folgen und ergriffene Gegenmaßnahmen — entsprechend Art. 33 DSGVO.</p>
              </details>

              <details class="tc__faq-item">
                <summary class="tc__faq-q">
                  Ist ein AV-Vertrag verfügbar?
                  <span class="tc__faq-icon" aria-hidden="true"></span>
                </summary>
                <p class="tc__faq-a">Ja. Der vollständige Auftragsverarbeitungsvertrag nach Art. 28 DSGVO inklusive TOMs und Subprozessoren-Liste wird pro Unternehmen beim Onboarding unterzeichnet. Auf Anfrage kann das Dokument vorab zugesendet werden.</p>
              </details>

            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── CTA ─── -->
    <section class="tc__cta section-fade">
      <div class="container">
        <div class="tc__cta-inner">
          <p class="tc__cta-eyebrow">Jetzt starten</p>
          <h2 class="tc__cta-heading">
            <span>Bereit, Ihrer Organisation</span>
            <span class="tc__cta-heading--faded">eine Stimme zu geben?</span>
          </h2>
          <p class="tc__cta-sub">Erste Erkenntnisse in 3–4 Tagen. Kein aufwendiges Onboarding. Kein Setup-Aufwand.</p>
          <a href="/de/#request-pilot" class="tc__cta-btn">
            <span class="tc__cta-btn-label">Zur Warteliste</span>
            <i class="tc__cta-btn-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </i>
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer lang="de" />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.06, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.section-fade').forEach((el) => observer.observe(el));
</script>

<style>
  /* ── Page shell ── */
  .tc {
    padding-bottom: var(--space-section);
  }

  /* ── Hero ── */
  .tc__hero {
    padding: var(--space-section-lg) 0 var(--space-section);
    border-bottom: 1px solid var(--color-border);
  }

  .tc__eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .tc__hero-heading {
    font-size: clamp(var(--text-2xl), 7vw, var(--text-4xl));
    font-weight: 800 !important;
    letter-spacing: -0.04em !important;
    line-height: 1.0;
    display: flex;
    flex-direction: column;
    gap: 0.04em;
    margin-bottom: var(--space-8);
  }

  .tc__hero-line1 { color: var(--color-text-primary); }
  .tc__hero-line2 { color: var(--color-text-primary); opacity: 0.3; }

  .tc__hero-sub {
    font-size: clamp(var(--text-base), 2vw, var(--text-lg));
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 640px;
    margin-bottom: var(--space-12);
  }

  /* Badges */
  .tc__badges {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    max-width: 760px;
  }

  @media (min-width: 640px) {
    .tc__badges { grid-template-columns: repeat(4, 1fr); }
  }

  .tc__badge {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }

  .tc__badge-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-ui);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .tc__badge div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tc__badge strong {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .tc__badge span {
    font-size: 11px;
    color: var(--color-text-tertiary);
    line-height: 1.4;
  }

  /* ── Sections ── */
  .tc__section {
    padding: var(--space-16) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .tc__section-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .tc__section-inner {
      grid-template-columns: 200px 1fr;
      gap: var(--space-16);
    }
  }

  .tc__section-label {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    padding-top: 6px;
  }

  @media (min-width: 768px) {
    .tc__section-label {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .tc__section-num {
    font-size: var(--text-xl);
    font-weight: 800 !important;
    letter-spacing: -0.04em !important;
    color: var(--color-border);
    line-height: 1;
  }

  .tc__section-heading {
    font-size: clamp(var(--text-lg), 3vw, var(--text-xl));
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    color: var(--color-text-primary);
    line-height: 1.1;
    margin-bottom: var(--space-4);
  }

  .tc__section-text {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.8;
    max-width: 640px;
    margin-bottom: var(--space-6);
  }

  /* ── List ── */
  .tc__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .tc__list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .tc__list li::before {
    content: '';
    width: 5px;
