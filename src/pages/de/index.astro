---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import TheProblem from '../../components/TheProblem.astro';
import ValidationLoop from '../../components/ValidationLoop.astro';
import Testimonial from '../../components/Testimonial.astro';
import USP from '../../components/USP.astro';
import DemoCTA from '../../components/DemoCTA.astro';
import Footer from '../../components/Footer.astro';
import { ProductPreviewScroll } from '../../components/ui/product-preview-scroll';

const lang = 'de';
---

<Layout
  title="implicit.ai — KI-gestützte Innovationsintelligenz"
  description="implicit.ai hebt schwache Signale aus Ihrer Organisation an die Oberfläche und verwandelt sie in validierte Innovationsmöglichkeiten."
  lang="de"
>
  <Nav lang={lang} />
  <main>
    <Hero lang={lang} />
    <ProductPreviewScroll lang={lang} client:visible />
    <HowItWorks lang={lang} />
    <TheProblem lang={lang} />
    <ValidationLoop lang={lang} />
    <Testimonial lang={lang} />
    <USP lang={lang} />
    <DemoCTA lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.section-fade').forEach((el) => observer.observe(el));
</script>
